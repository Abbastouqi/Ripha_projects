# Copy this file to .env and fill in your Supabase credentials
# Get from: https://app.supabase.com -> Project Settings -> API

SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_KEY=your_service_role_key_here

# ── Face recognition ──────────────────────────────────────────────────────────
# Cosine similarity on L2-normalized 512D ArcFace vectors
# Same person: ~0.65-0.99  |  Different person: ~0.10-0.50
# Do NOT go below 0.55 — causes false matches
SIMILARITY_THRESHOLD=0.60

# ── Camera ───────────────────────────────────────────────────────────────────
# 0 = built-in webcam, 1 = first external USB camera
CAMERA_ID=0

# Process every Nth frame (5 = ~6fps from a 30fps camera)
# Increase to 10 on slow machines; decrease to 3 for faster response
FRAME_SKIP=5

# ── Attendance timing ────────────────────────────────────────────────────────
# Seconds of absence before auto check-out (default: 300 = 5 minutes)
CHECKOUT_TIMEOUT_SEC=300

# ── InsightFace model ────────────────────────────────────────────────────────
# buffalo_sc  — MobileFaceNet, fast, CPU-optimized (~100MB)
# buffalo_l   — ResNet100 + ArcFace, higher accuracy (~1GB, slower on CPU)
INSIGHTFACE_MODEL=buffalo_sc
